// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   30       0     0     0>  // row 0
            , <&key_physical_attrs 100 100  100   20       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   10       0     0     0>
            , <&key_physical_attrs 100 100  500   20       0     0     0>

            , <&key_physical_attrs 100 100  900   20       0     0     0>
            , <&key_physical_attrs 100 100 1000   10       0     0     0>
            , <&key_physical_attrs 100 100 1100    0       0     0     0>
            , <&key_physical_attrs 100 100 1200    0       0     0     0>
            , <&key_physical_attrs 100 100 1300   20       0     0     0>
            , <&key_physical_attrs 100 100 1400   30       0     0     0>


            , <&key_physical_attrs 100 100    0  130       0     0     0>  // row 1
            , <&key_physical_attrs 100 100  100  120       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  110       0     0     0>
            , <&key_physical_attrs 100 100  500  120       0     0     0>

            , <&key_physical_attrs 100 100  900  120       0     0     0>
            , <&key_physical_attrs 100 100 1000  110       0     0     0>
            , <&key_physical_attrs 100 100 1100  100       0     0     0>
            , <&key_physical_attrs 100 100 1200  100       0     0     0>
            , <&key_physical_attrs 100 100 1300  120       0     0     0>
            , <&key_physical_attrs 100 100 1400  130       0     0     0>


            , <&key_physical_attrs 100 100    0  230       0     0     0> // row 2
            , <&key_physical_attrs 100 100  100  220       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  210       0     0     0>
            , <&key_physical_attrs 100 100  500  220       0     0     0>

            , <&key_physical_attrs 100 100  900  220       0     0     0>
            , <&key_physical_attrs 100 100 1000  210       0     0     0>
            , <&key_physical_attrs 100 100 1100  200       0     0     0>
            , <&key_physical_attrs 100 100 1200  200       0     0     0>
            , <&key_physical_attrs 100 100 1300  220       0     0     0>
            , <&key_physical_attrs 100 100 1400  230       0     0     0>

            , <&key_physical_attrs 100 100    0  330       0     0     0>  // row 3
            , <&key_physical_attrs 100 100  100  320       0     0     0>
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 100 100  400  310       0     0     0>
            , <&key_physical_attrs 100 100  500  320       0     0     0>

            , <&key_physical_attrs 100 100  900  320       0     0     0>
            , <&key_physical_attrs 100 100 1000  310       0     0     0>
            , <&key_physical_attrs 100 100 1100  300       0     0     0>
            , <&key_physical_attrs 100 100 1200  300       0     0     0>
            , <&key_physical_attrs 100 100 1300  320       0     0     0>
            , <&key_physical_attrs 100 100 1400  330       0     0     0>

            , <&key_physical_attrs 100 100  250  400       0     0     0>  // row 4
            , <&key_physical_attrs 100 100  350  400       0     0     0>
            , <&key_physical_attrs 100 100  450  410       0     0     0>
            , <&key_physical_attrs 100 100  550  420       0     0     0>
            , <&key_physical_attrs 100 100  600  270       0     0     0>

            , <&key_physical_attrs 100 100  800  270       0     0     0>
            , <&key_physical_attrs 100 100  850  420       0     0     0>
            , <&key_physical_attrs 100 100  950  410       0     0     0>
            , <&key_physical_attrs 100 100 1050  400       0     0     0>
            , <&key_physical_attrs 100 100 1150  400       0     0     0>
            ;
    };
};
